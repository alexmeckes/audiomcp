{
  "name": "@genai-gametools/audio-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI-powered game audio generation - music, sound effects, and voice",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "genai-audio-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "audio-generation",
    "ai",
    "gamedev",
    "game-development",
    "sound-effects",
    "music-generation",
    "elevenlabs",
    "suno",
    "stable-audio"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
